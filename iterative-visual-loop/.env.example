# Google GenAI Setup
API_KEY=your_google_genai_api_key_here

# Webhook (optional)
WEBHOOK_URL=https://your-webhook-endpoint.com/events
WEBHOOK_API_KEY=your_webhook_api_key

# Application
VITE_PORT=5173
VITE_HOST=localhost

# Agent Configuration
MAX_REQUESTS_PER_MINUTE=5
MIN_DELAY_BETWEEN_REQUESTS_MS=12000
MAX_ITERATIONS=20

# Rate Limiting
ENABLE_RATE_LIMITING=true
BACKOFF_FACTOR=2

# Logging
VITE_LOG_LEVEL=info

# Screenshot
SCREENSHOT_QUALITY=50
SCREENSHOT_SCALE=1
SCREENSHOT_FILE_NAME=screenshot
